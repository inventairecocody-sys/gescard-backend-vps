# Crée le fichier .gitignore
@"
# ==============================
# NODE
# ==============================
node_modules/

# ==============================
# VARIABLES D'ENVIRONNEMENT
# ==============================
.env
.env.local
.env.production
.env.development

# ==============================
# FICHIERS SENSIBLES
# ==============================
google-tokens-backup.json
get-token.js
consolider.js

# ==============================
# RENDER
# ==============================
render.yaml

# ==============================
# LOGS
# ==============================
logs/
*.log
npm-debug.log*

# ==============================
# UPLOADS (garder le dossier mais pas les fichiers)
# ==============================
uploads/*
!uploads/.gitkeep

# ==============================
# BACKUPS LOCAUX
# ==============================
backups/
*.dump
*.sql
*.gz

# ==============================
# FICHIERS SYSTEME
# ==============================
.DS_Store
Thumbs.db

# ==============================
# IDE / EDITEURS
# ==============================
.vscode/
.idea/
*.swp
*.swo
"@ | Out-File -FilePath .gitignore -Encoding utf8